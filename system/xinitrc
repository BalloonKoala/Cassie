#!/bin/sh
# Cassie kiosk display — copied to ~/.xinitrc on install/update
export DISPLAY=:0

xset s off
xset -dpms
xset s noblank
unclutter -idle 0.5 -root &

# Wait for backend HTTP (up to 90s)
for i in $(seq 1 90); do
  if curl -sf http://127.0.0.1:8766/ >/dev/null 2>&1; then
    break
  fi
  sleep 1
done

URL="http://127.0.0.1:8766/"

if command -v chromium-browser >/dev/null 2>&1; then
  exec chromium-browser --kiosk --noerrdialogs --disable-infobars \
    --disable-session-crashed-bubble --no-first-run \
    --check-for-update-interval=31536000 "$URL"
elif command -v chromium >/dev/null 2>&1; then
  exec chromium --kiosk --noerrdialogs --disable-infobars \
    --disable-session-crashed-bubble --no-first-run \
    --check-for-update-interval=31536000 "$URL"
else
  echo "No chromium found" >&2
  exec xterm
fi
