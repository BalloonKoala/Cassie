#!/bin/sh
export DISPLAY=:0

xset s off
xset -dpms
xset s noblank
xsetroot -solid '#000000'
unclutter -idle 0.5 -root &

/opt/cassie/system/keep-awake.sh &
sleep 3
xrandr --auto 2>/dev/null || true

if command -v matchbox-window-manager >/dev/null 2>&1; then
  matchbox-window-manager -use_titlebar no &
fi
sleep 1

for i in $(seq 1 120); do
  if curl -sf http://127.0.0.1:8766/ 2>/dev/null | grep -q getContext; then
    break
  fi
  sleep 1
done

URL="http://127.0.0.1:8766/"

if command -v chromium-browser >/dev/null 2>&1; then
  BROWSER=chromium-browser
elif command -v chromium >/dev/null 2>&1; then
  BROWSER=chromium
else
  exec xterm
fi

FLAGS="--kiosk --start-maximized --noerrdialogs --disable-infobars --no-first-run \
  --disable-session-crashed-bubble --disable-restore-session-state \
  --check-for-update-interval=31536000 --disk-cache-size=1 \
  --disable-background-timer-throttling --disable-renderer-backgrounding \
  --disable-backgrounding-occluded-windows \
  --disable-features=CalculateNativeWinOcclusion,IntensiveWakeUpThrottling"

# Restart browser if it crashes or goes blank
while true; do
  "$BROWSER" $FLAGS "$URL"
  sleep 3
done
